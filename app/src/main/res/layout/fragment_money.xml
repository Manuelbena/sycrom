<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ly_header_money"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_card"
        android:padding="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ahorros"
            android:textColor="#111111"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/headerIcons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="@id/tvTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvTitle">

            <ImageButton
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_settings"
                app:tint="#555" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_tab_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/color_body"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:strokeWidth="0dp">

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout_filters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                app:tabMode="fixed"
                app:tabGravity="center"
                app:tabRippleColor="@null"
                app:tabSelectedTextColor="@color/md_theme_onSurface"
                android:fontFamily="@font/nunitoextrabold"
                android:textSize="18sp"
                android:textColor="@color/md_theme_onSurface"
                app:tabTextAppearance="@style/PremiumTabTextAppearance"

                app:tabBackground="@android:color/transparent"
                app:tabIndicator="@drawable/tab_indicator_premium"
                app:tabIndicatorGravity="stretch"
                app:tabIndicatorFullWidth="true"
                app:tabIndicatorAnimationMode="elastic" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/card_tab_container"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/layoutMonthHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/color_body"
                android:padding="8dp">

                <ImageButton
                    android:id="@+id/btnPrevMonth"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/md_theme_onSurface"
                    android:contentDescription="Mes anterior" />

                <TextView
                    android:id="@+id/tvMonthTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    tools:text="Diciembre 2025"
                    android:textAlignment="center"
                    android:fontFamily="@font/nunitoextrabold"
                    android:textSize="18sp"
                    android:textColor="@color/md_theme_onSurface" />

                <ImageButton
                    android:id="@+id/btnNextMonth"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:rotation="180"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/md_theme_onSurface"
                    android:contentDescription="Mes siguiente" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_body"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ly_header_money">

        <include
            android:id="@+id/viewGeneral"
            layout="@layout/layout_money_overview"
            android:visibility="visible" />

        <include
            android:id="@+id/viewBudgets"
            layout="@layout/layout_skeleton_task"
            android:visibility="gone" />

        <include
            android:id="@+id/viewGoals"
            layout="@layout/layout_metas_section"
            android:visibility="gone" />

        <include
            android:id="@+id/viewHistory"
            layout="@layout/layout_history_section"
            android:visibility="gone" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddBudget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:fontFamily="@font/nunitobold"
        android:text="Nuevo Presupuesto"
        android:textColor="@color/white"
        android:visibility="gone"
        app:backgroundTint="@color/md_theme_primary"
        app:icon="@drawable/ic_finance"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/fabAddGoal"
        app:layout_constraintEnd_toEndOf="@+id/fabMain" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddGoal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:fontFamily="@font/nunitobold"
        android:text="Nueva Meta"
        android:textColor="@color/white"
        android:visibility="gone"
        app:backgroundTint="@color/md_theme_primary"
        app:icon="@drawable/ic_mark"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/fabAddIncome"
        app:layout_constraintEnd_toEndOf="@+id/fabMain" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddIncome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:fontFamily="@font/nunitobold"
        android:text="Nuevo Ingreso"
        android:textColor="@color/white"
        android:visibility="gone"
        app:backgroundTint="#10B981"
        app:icon="@drawable/banknote_arrow_up"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/fabAddExpense"
        app:layout_constraintEnd_toEndOf="@+id/fabMain" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddExpense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:fontFamily="@font/nunitobold"
        android:text="Nuevo Gasto"
        android:textColor="@color/white"
        android:visibility="gone"
        app:backgroundTint="#EF4444"
        app:icon="@drawable/banknote_arrow_down"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/fabMain"
        app:layout_constraintEnd_toEndOf="@+id/fabMain" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/spacing_large"
        android:layout_marginBottom="100dp"
        android:contentDescription="Abrir menú"
        app:backgroundTint="@color/md_theme_primary"
        app:elevation="6dp"
        app:fabSize="normal"
        app:srcCompat="@drawable/ic_plus"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>