<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/tv_timeline_time_start"
        android:layout_width="45dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/nunitobold"
        android:textColor="@color/md_theme_onSurface"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/card_task"
        tools:text="08:00" />

    <View
        android:id="@+id/iv_timeline_dot_start"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/shape_circle_background"
        android:backgroundTint="#D1D5DB"
        app:layout_constraintBottom_toBottomOf="@id/tv_timeline_time_start"
        app:layout_constraintEnd_toStartOf="@id/card_task"
        app:layout_constraintTop_toTopOf="@id/tv_timeline_time_start" />

    <TextView
        android:id="@+id/tv_timeline_time_end"
        android:layout_width="45dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/nunitobold"
        android:textColor="@color/secondary_text"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/card_task"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="17:00" />

    <View
        android:id="@+id/iv_timeline_dot_end"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/shape_circle_background"
        android:backgroundTint="#D1D5DB"
        app:layout_constraintBottom_toBottomOf="@id/tv_timeline_time_end"
        app:layout_constraintEnd_toStartOf="@id/card_task"
        app:layout_constraintStart_toStartOf="@id/iv_timeline_dot_start"
        app:layout_constraintTop_toTopOf="@id/tv_timeline_time_end" />

    <View
        android:id="@+id/view_line_middle"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#E5E7EB"
        app:layout_constraintBottom_toTopOf="@id/iv_timeline_dot_end"
        app:layout_constraintEnd_toEndOf="@id/iv_timeline_dot_start"
        app:layout_constraintStart_toStartOf="@id/iv_timeline_dot_start"
        app:layout_constraintTop_toBottomOf="@id/iv_timeline_dot_start" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_task"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:minHeight="80dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tv_timeline_time_start"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">


            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cb_task_done"
                android:layout_width="@dimen/icon_size_lg"
                android:layout_height="@dimen/icon_size_lg"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_task_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/nunitobold"
                android:textColor="@color/md_theme_onSurface"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="@id/cb_task_done"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/cb_task_done"
                app:layout_constraintTop_toTopOf="@id/cb_task_done"
                tools:text="Trabajo \uD83D\uDCBC" />

            <TextView
                android:id="@+id/tv_task_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/secondary_text"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/tv_task_title"
                app:layout_constraintTop_toBottomOf="@id/tv_task_title"
                tools:text="Vamos a por otro día más" />

            <LinearLayout
                android:id="@+id/lySubtasksHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/tv_task_title"
                app:layout_constraintTop_toBottomOf="@+id/tv_task_subtitle">

                <ImageView
                    android:id="@+id/ivChevron"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:rotation="-90"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/secondary_text" />

                <TextView
                    android:id="@+id/textView_taskDetail_progressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/nunitregular"
                    android:textColor="@color/secondary_text"
                    android:textSize="12sp"
                    tools:text="Subtareas (1/3)" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llSubtasksContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/tv_task_title"
                app:layout_constraintTop_toBottomOf="@+id/lySubtasksHeader">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSubtasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llTags"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/tv_task_title"
                app:layout_constraintTop_toBottomOf="@+id/llSubtasksContainer">

                <TextView
                    android:id="@+id/tvCategoryTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_tag_background_prymary"
                    android:fontFamily="@font/nunitobold"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/color_surface"
                    android:textSize="11sp"
                    tools:text="Trabajo" />

                <TextView
                    android:id="@+id/tvPriorityTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/shape_tag_background_hight"
                    android:fontFamily="@font/nunitobold"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:textColor="#DC2626"
                    android:textSize="11sp"
                    tools:text="ALTA" />
            </LinearLayout>

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottie_celebration"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:scaleType="centerCrop"
                android:translationZ="10dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:lottie_autoPlay="false"
                app:lottie_loop="false"
                app:lottie_rawRes="@raw/confetti" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_current_time_indicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/card_task"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/iv_timeline_dot_start"
        app:layout_constraintTop_toTopOf="@id/card_task"
        app:layout_constraintVertical_bias="0.5"
        tools:visibility="visible">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottie_current_time"
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/direct"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/view_current_time_line"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_marginEnd="8dp"
            android:background="#10B981"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_current_time_bubble"
            app:layout_constraintStart_toEndOf="@id/lottie_current_time"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_current_time_bubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_task_today_gradient"
            android:backgroundTint="#10B981"
            android:fontFamily="@font/nunitobold"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="13:38" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>