<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#E5E7EB"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_category_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#FFEDD5"
            android:padding="12dp"
            android:scaleType="centerInside"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
            tools:src="@drawable/ic_habiut"
            tools:tint="#EA580C" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_category_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#1F2937"
            android:textSize="16sp"
            app:layout_constraintBottom_toTopOf="@+id/tv_category_limit"
            app:layout_constraintEnd_toStartOf="@+id/btn_edit"
            app:layout_constraintStart_toEndOf="@id/iv_category_icon"
            app:layout_constraintTop_toTopOf="@id/iv_category_icon"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="Alimentación" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_category_limit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#6B7280"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/iv_category_icon"
            app:layout_constraintEnd_toEndOf="@id/tv_category_title"
            app:layout_constraintStart_toStartOf="@id/tv_category_title"
            app:layout_constraintTop_toBottomOf="@id/tv_category_title"
            tools:text="Límite: 600,00 €" />

        <ImageButton
            android:id="@+id/btn_edit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Editar presupuesto"
            android:src="@drawable/ic_edit"
            app:layout_constraintBottom_toBottomOf="@id/iv_category_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iv_category_icon" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lbl_spent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Gastado"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@+id/lbl_available"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_category_icon" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lbl_available"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Disponible"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/lbl_spent"
            app:layout_constraintEnd_toStartOf="@+id/lbl_used"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/lbl_spent"
            app:layout_constraintTop_toTopOf="@id/lbl_spent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lbl_used"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Usado"
            android:textColor="#9CA3AF"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/lbl_spent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toEndOf="@id/lbl_available"
            app:layout_constraintTop_toTopOf="@id/lbl_spent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_spent_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-bold"
            android:textColor="#111827"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/lbl_spent"
            app:layout_constraintStart_toStartOf="@id/lbl_spent"
            app:layout_constraintTop_toBottomOf="@id/lbl_spent"
            tools:text="380,00 €" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_available_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-bold"
            android:textColor="#10B981"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@id/tv_spent_value"
            app:layout_constraintEnd_toEndOf="@id/lbl_available"
            app:layout_constraintStart_toStartOf="@id/lbl_available"
            app:layout_constraintTop_toTopOf="@id/tv_spent_value"
            tools:text="220,00 €" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_used_percent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-bold"
            android:textColor="#10B981"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@id/tv_spent_value"
            app:layout_constraintEnd_toEndOf="@id/lbl_used"
            app:layout_constraintStart_toStartOf="@id/lbl_used"
            app:layout_constraintTop_toTopOf="@id/tv_spent_value"
            tools:text="63%" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/lpi_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:indicatorColor="#F97316"
            app:layout_constraintTop_toBottomOf="@id/tv_spent_value"
            app:trackColor="#F3F4F6"
            app:trackCornerRadius="4dp"
            app:trackThickness="8dp"
            tools:progress="63" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>