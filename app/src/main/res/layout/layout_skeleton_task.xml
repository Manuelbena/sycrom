<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:layout_marginBottom="@dimen/space_card_width"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_main_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_main_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Resumen de presupuestos"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@+id/btn_add_budget"
                    app:layout_constraintEnd_toStartOf="@+id/btn_add_budget"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/btn_add_budget" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_budget"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:backgroundTint="#8B5CF6"
                    android:contentDescription="Añadir presupuesto"
                    app:icon="@drawable/ic_add"
                    app:iconTint="@android:color/white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_total_spent_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Total gastado"
                    android:textColor="#6B7280"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btn_add_budget" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_total_limit_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#6B7280"
                    android:textSize="14sp"
                    app:layout_constraintBottom_toBottomOf="@id/tv_total_spent_label"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_total_spent_label"
                    tools:text="de 1750,00 €" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_total_spent_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_total_spent_label"
                    tools:text="380,00 €" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_total_spent_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="#10B981"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/tv_total_spent_value"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_total_spent_value"
                    tools:text="22%" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/lpi_total_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:indicatorColor="#10B981"
                    app:layout_constraintTop_toBottomOf="@id/tv_total_spent_value"
                    app:trackColor="#F3F4F6"
                    app:trackCornerRadius="4dp"
                    app:trackThickness="8dp"
                    tools:progress="22" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/cpi_donut_chart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="24dp"
                    app:indicatorColor="#8B5CF6"
                    app:indicatorSize="160dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/lpi_total_progress"
                    app:trackColor="#E5E7EB"
                    app:trackThickness="28dp"
                    tools:progress="85" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_budget_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/card_main_summary"
            tools:itemCount="3"
            tools:listitem="@layout/item_budget_category" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>