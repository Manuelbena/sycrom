<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_home">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/lyHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_theme_surface"
        android:fitsSystemWindows="true"
        app:elevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clHeaderContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/spacing_large"
            android:paddingTop="@dimen/spacing_medium"
            android:paddingBottom="@dimen/spacing_medium">

            <TextView
                android:id="@+id/textGreeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_medium"
                android:fontFamily="@font/nunitoextrabold"
                android:maxLines="1"
                android:text="@string/home_greeting_placeholder"

                android:textColor="@color/md_theme_onSurface"
                android:textSize="@dimen/text_h5"
                app:layout_constraintEnd_toStartOf="@+id/lyWeatherActions"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Hola, Manuel" />

            <TextView
                android:id="@+id/textDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_tiny"
                android:fontFamily="@font/nunitosemibold"
                android:text="@string/home_date_placeholder"
                android:textColor="@color/secondary_text"
                android:textSize="@dimen/text_body"
                app:layout_constraintStart_toStartOf="@id/textGreeting"
                app:layout_constraintTop_toBottomOf="@id/textGreeting"
                app:layout_constraintBottom_toTopOf="@+id/dividerHeader"
                tools:text="12 de mayo de 2025" />

            <LinearLayout
                android:id="@+id/lyWeatherActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="@+id/textDate"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/textGreeting">

                <LinearLayout
                    android:id="@+id/lyWeatherWidget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_s"
                    android:paddingVertical="@dimen/spacing_small">

                    <ImageView
                        android:id="@+id/iconWeather"
                        android:layout_width="@dimen/icon_small"
                        android:layout_height="@dimen/icon_small"
                        android:contentDescription="@string/cd_weather_icon"
                        android:src="@drawable/ic_sol"
                        app:tint="@color/md_theme_onSurface" />

                    <TextView
                        android:id="@+id/textTemperature"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_small"
                        android:fontFamily="@font/nunitobold"
                        android:text="@string/home_temp_placeholder"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="@dimen/text_body"
                        tools:text="17°C" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSettings"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="@dimen/spacing_2xl"
                    android:layout_height="@dimen/spacing_2xl"
                    android:layout_marginStart="@dimen/spacing_tiny"
                    android:contentDescription="@string/cd_settings"
                    app:icon="@drawable/ic_settings"
                    app:iconTint="@color/md_theme_onSurface" />
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:id="@+id/dividerHeader"
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:layout_marginTop="@dimen/spacing_large"
                app:dividerColor="?attr/colorOutline"
                app:layout_constraintTop_toBottomOf="@+id/textDate" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lyHeader">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nested_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="100dp"
            android:fillViewport="true"> <LinearLayout
            android:id="@+id/ly_body_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:background="@color/color_body"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/lyCalendarContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/spacing_large"
                android:background="@color/md_theme_surface"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@+id/dividerHeader">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_medium"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvMonthYear"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/nunitobold"
                        android:text="@string/home_calendar_placeholder"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="@dimen/text_h2"
                        tools:text="Diciembre 2025" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToday"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunitobold"
                        android:minHeight="40dp"
                        android:text="@string/home_btn_today"
                        android:textColor="@color/md_theme_onSurface"
                        android:textSize="@dimen/text_body"
                        app:backgroundTint="@color/color_body" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_small"
                    android:orientation="horizontal">
                    <TextView style="@style/CalendarDayLegend" android:text="@string/day_short_mon" android:textSize="@dimen/text_caption" />
                    <TextView style="@style/CalendarDayLegend" android:text="@string/day_short_tue" android:textSize="@dimen/text_caption" />
                    <TextView style="@style/CalendarDayLegend" android:text="@string/day_short_wed" android:textSize="@dimen/text_caption" />
                    <TextView style="@style/CalendarDayLegend" android:text="@string/day_short_thu" android:textSize="@dimen/text_caption" />
                    <TextView style="@style/CalendarDayLegend" android:text="@string/day_short_fri" android:textSize="@dimen/text_caption" />
                    <TextView style="@style/CalendarDayLegend" android:text="@string/day_short_sat" android:textSize="@dimen/text_caption" />
                    <TextView style="@style/CalendarDayLegend" android:text="@string/day_short_sun" android:textSize="@dimen/text_caption" />
                </LinearLayout>

                <com.kizitonwose.calendar.view.WeekCalendarView
                    android:id="@+id/weekCalendarView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cv_dayViewResource="@layout/item_calendar_day_new" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQuote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_medium"
                app:cardBackgroundColor="@color/color_card"
                app:cardCornerRadius="@dimen/card_corner_radius_lg"
                app:cardElevation="@dimen/card_elevation"
                android:layout_marginHorizontal="@dimen/spacing_large"
                app:strokeWidth="@dimen/card_stroke_width"
                android:layout_marginTop="@dimen/spacing_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_medium">
                    <TextView
                        android:id="@+id/tvQuoteText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunitosemibold"
                        android:text="Cargando inspiración..."
                        android:textSize="@dimen/text_body"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/md_theme_onSurface"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvQuoteAuthor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunitobold"
                        android:text="— Autor"
                        android:textSize="@dimen/text_caption"
                        android:textColor="@color/secondary_text"
                        android:gravity="end"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/lySuperTasksContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/nunitoextrabold"
                    android:text="Super Tareas"
                    android:textSize="18sp"
                    android:textColor="#1F2937"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSuperTasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipChildren="false"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:clipToPadding="false"
                    android:paddingBottom="16dp"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_super_task_card" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/nunitoextrabold"
                    android:text="@string/home_tasks_title"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/text_h2" />

                <com.google.android.material.loadingindicator.LoadingIndicator
                    android:id="@+id/progress_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:indicatorSize="40dp" />

                <LinearLayout
                    android:id="@+id/ivNoTasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_large"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:contentDescription="@string/cd_no_tasks"
                        android:src="@drawable/synkrom_sintareas" />
                    <TextView
                        android:id="@+id/tvNoTasks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_medium"
                        android:fontFamily="@font/nunitosemibold"
                        android:gravity="center"
                        android:text="@string/home_tasks_empty_title"
                        android:textColor="#6B7280"
                        android:textSize="@dimen/txt_xl" />
                </LinearLayout>

                <com.facebook.shimmer.ShimmerFrameLayout
                    android:id="@+id/shimmerViewContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:shimmer_duration="800">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="20dp">
                        <include layout="@layout/layout_skeleton_task" />
                        <include layout="@layout/layout_skeleton_task" />
                        <include layout="@layout/layout_skeleton_task" />
                    </LinearLayout>
                </com.facebook.shimmer.ShimmerFrameLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewTasks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"  android:orientation="vertical"
                    android:clipChildren="false"
                    android:paddingHorizontal="16dp"
                    android:clipToPadding="false"
                    android:layout_marginTop="16dp"
                    android:visibility="visible"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_task_timeline" />

            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:padding="@dimen/spacing_large">

                <TextView
                    android:id="@+id/tvHeaderResumen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_medium"
                    android:fontFamily="@font/nunitobold"
                    android:text="@string/home_summary_title"
                    android:textColor="@color/secondary_text"
                    android:textSize="@dimen/text_h2"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProd"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_medium"
                    android:layout_marginEnd="@dimen/spacing_small"
                    app:cardBackgroundColor="@color/color_card"
                    app:cardCornerRadius="@dimen/card_corner_radius_lg"
                    app:cardElevation="@dimen/card_elevation_default"
                    app:layout_constraintEnd_toStartOf="@+id/cardHabits"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/tvHeaderResumen"
                    app:strokeColor="@color/border"
                    app:strokeWidth="@dimen/card_stroke_width">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/spacing_medium">

                        <ImageView
                            android:id="@+id/ivProdIcon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_cicle_purpple"
                            android:padding="@dimen/spacing_small"
                            android:src="@drawable/ic_finance"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="?attr/colorSurface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_s"
                            android:fontFamily="@font/nunitosemibold"
                            android:text="@string/home_card_prod_title"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/text_body"
                            app:layout_constraintBottom_toBottomOf="@+id/ivProdIcon"
                            app:layout_constraintStart_toEndOf="@+id/ivProdIcon"
                            app:layout_constraintTop_toTopOf="@+id/ivProdIcon" />

                        <TextView
                            android:id="@+id/tvProdValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_medium"
                            android:fontFamily="@font/nunitoextrabold"
                            android:text="85%"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/text_h5"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/ivProdIcon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/nunitregular"
                            android:text="@string/home_card_prod_subtitle"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/text_caption"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/tvProdValue" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHabits"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:layout_marginTop="@dimen/spacing_medium"
                    app:cardBackgroundColor="@color/color_card"
                    app:cardCornerRadius="@dimen/card_corner_radius_lg"
                    app:cardElevation="@dimen/card_elevation_default"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/cardProd"
                    app:layout_constraintTop_toBottomOf="@+id/tvHeaderResumen"
                    app:strokeColor="@color/border"
                    app:strokeWidth="@dimen/card_stroke_width">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/spacing_medium">

                        <ImageView
                            android:id="@+id/ivHabitIcon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_cicle_green"
                            android:padding="@dimen/spacing_small"
                            android:src="@drawable/ic_habiut"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="?attr/colorSurface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_s"
                            android:fontFamily="@font/nunitosemibold"
                            android:text="@string/home_card_habits_title"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/text_body"
                            app:layout_constraintBottom_toBottomOf="@+id/ivHabitIcon"
                            app:layout_constraintStart_toEndOf="@+id/ivHabitIcon"
                            app:layout_constraintTop_toTopOf="@+id/ivHabitIcon" />

                        <TextView
                            android:id="@+id/tvHabitValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_medium"
                            android:fontFamily="@font/nunitoextrabold"
                            android:text="5/7"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/text_h5"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/ivHabitIcon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/nunitregular"
                            android:text="@string/home_card_habits_subtitle"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/text_caption"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/tvHabitValue" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBalance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/text_caption"
                    app:cardBackgroundColor="@color/color_card"
                    app:cardCornerRadius="@dimen/card_corner_radius_lg"
                    app:cardElevation="@dimen/card_elevation_default"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/cardProd"
                    app:strokeColor="@color/border"
                    app:strokeWidth="@dimen/card_stroke_width">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/spacing_large">

                        <ImageView
                            android:id="@+id/ivBalanceIcon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_cicle_blue"
                            android:padding="@dimen/spacing_small"
                            android:src="@drawable/ic_banck"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"

                            app:tint="?attr/colorSurface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_s"
                            android:fontFamily="@font/nunitosemibold"
                            android:text="@string/home_card_balance_title"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/text_body"
                            app:layout_constraintBottom_toBottomOf="@+id/ivBalanceIcon"
                            app:layout_constraintStart_toEndOf="@+id/ivBalanceIcon"
                            app:layout_constraintTop_toTopOf="@+id/ivBalanceIcon" />

                        <TextView
                            android:id="@+id/tvBalanceValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_medium"
                            android:fontFamily="@font/nunitoextrabold"
                            android:text="$2,450"
                            android:textColor="@color/secondary_text"
                            android:textSize="@dimen/text_h5"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/ivBalanceIcon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_small"
                            android:fontFamily="@font/nunitobold"
                            android:text="+12.5% ↗"
                            android:textColor="@color/priority_low"
                            android:textSize="@dimen/text_caption"
                            app:layout_constraintBaseline_toBaselineOf="@+id/tvBalanceValue"
                            app:layout_constraintStart_toEndOf="@+id/tvBalanceValue" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/tvFabAddGasto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:fontFamily="@font/nunitobold"
        android:text="@string/fab_expense"
        android:textColor="@color/white"
        android:visibility="invisible"
        app:backgroundTint="@color/md_theme_primary"
        app:icon="@drawable/banknote_arrow_down"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/tvFabAddIng"
        app:layout_constraintEnd_toEndOf="@+id/tvFabAddIng" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/tvFabAddIng"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:fontFamily="@font/nunitobold"
        android:text="@string/fab_income"
        android:textColor="@color/white"
        android:visibility="invisible"
        app:backgroundTint="@color/md_theme_primary"
        app:icon="@drawable/banknote_arrow_up"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/tvFabAddSuggestion"
        app:layout_constraintEnd_toEndOf="@+id/tvFabAddSuggestion" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/tvFabAddSuggestion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_medium"
        android:fontFamily="@font/nunitobold"
        android:text="@string/fab_task_ai"
        android:textColor="@color/white"
        android:visibility="invisible"
        app:backgroundTint="@color/md_theme_primary"
        app:icon="@drawable/sparkle"
        app:iconTint="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/tvFabAddTask"
