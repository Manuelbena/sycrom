<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginBottom="@dimen/space_card_width"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_metas_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="#E5E7EB"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_metas_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="Mis metas de ahorro"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    app:layout_constraintBottom_toBottomOf="@+id/btn_add_meta"
                    app:layout_constraintEnd_toStartOf="@+id/btn_add_meta"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/btn_add_meta" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_meta"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:backgroundTint="#F3E8FF"
                    android:contentDescription="Añadir meta"
                    app:icon="@drawable/ic_add"
                    app:iconTint="#8B5CF6"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_total_progress_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Progreso total"
                    android:textColor="#6B7280"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btn_add_meta" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_total_saved_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total ahorrado"
                    android:textColor="#6B7280"
                    android:textSize="14sp"
                    app:layout_constraintBottom_toBottomOf="@id/tv_total_progress_label"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_total_progress_label" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_total_saved_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="#111827"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_total_progress_label"
                    tools:text="4.500,00 €" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_total_progress_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="#10B981"
                    android:textSize="24sp"
                    app:layout_constraintBottom_toBottomOf="@id/tv_total_saved_value"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_total_saved_value"
                    tools:text="65%" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/lpi_total_metas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:indicatorColor="#10B981"
                    app:layout_constraintTop_toBottomOf="@id/tv_total_saved_value"
                    app:trackColor="#F3F4F6"
                    app:trackCornerRadius="8dp"
                    app:trackThickness="16dp"
                    tools:progress="65" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_total_limit_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#6B7280"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/lpi_total_metas"
                    tools:text="de 6.900,00 €" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_saved_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ahorrados"
                    android:textColor="#6B7280"
                    android:textSize="14sp"
                    app:layout_constraintBottom_toBottomOf="@id/tv_total_limit_label"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_total_limit_label" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_upcoming_objectives"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-medium"
            android:text="Próximos objetivos"
            android:textColor="#111827"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_metas_summary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_upcoming_goals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_upcoming_objectives"
            tools:listitem="@layout/item_meta" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>