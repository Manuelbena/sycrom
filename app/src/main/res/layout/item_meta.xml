<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeColor="#E5E7EB"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btn_delete_goal"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:src="@drawable/ic_delete"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#EF4444" /> <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_percent_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#F9FAFB"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="#E5E7EB"
        app:strokeWidth="1dp">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_goal_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-bold"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:textColor="#111827"
            android:textSize="18sp"
            tools:text="85%" />
    </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_goal_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="sans-serif-bold"
            android:textColor="#111827"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@id/card_percent_container"
            app:layout_constraintEnd_toStartOf="@id/btn_delete_goal"
            app:layout_constraintStart_toEndOf="@id/card_percent_container"
            app:layout_constraintTop_toTopOf="@id/card_percent_container"
            tools:text="Coche nuevo" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/lpi_goal_item"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:indicatorColor="#F97316"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_percent_container"
            app:trackColor="#F3F4F6"
            app:trackCornerRadius="4dp"
            app:trackThickness="8dp"
            tools:progress="85" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_goal_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#4B5563"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lpi_goal_item"
            tools:text="10.000 € / 12.000 €" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_time_remaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="#A855F7"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tv_goal_progress"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_goal_progress"
            tools:text="Quedan 2 meses" />

        <View
            android:id="@+id/divider_goal"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#E5E7EB"
            app:layout_constraintTop_toBottomOf="@id/tv_goal_progress" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_suggestion_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="sans-serif"
            android:textColor="#6B7280"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider_goal"
            tools:text="Para alcanzar tu meta a tiempo deberías ahorrar 1.000 € al mes." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="3"
            app:layout_constraintTop_toBottomOf="@id/tv_suggestion_text">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_10"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="+ 10 €"
                android:textColor="#111827"
                android:textSize="12sp"
                app:backgroundTint="#F3F4F6"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_50"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="+ 50 €"
                android:textColor="#111827"
                android:textSize="12sp"
                app:backgroundTint="#F3F4F6"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_custom"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Otro"
                android:textColor="#8B5CF6"
                android:textSize="12sp"
                app:cornerRadius="8dp"
                app:icon="@drawable/ic_edit"
                app:iconSize="16dp"
                app:iconTint="#8B5CF6"
                app:strokeColor="#8B5CF6" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>